APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug
LOG_ENDPOINT_QUERIES_LEVEL=info
LOG_ENDPOINT_QUERIES_DAYS=30

DB_CONNECTION=sqlsrv_main

# Conexión principal a SQL Server (para tablas de la app como api_tokens)
SQLSRV_MAIN_DRIVER=sqlsrv
SQLSRV_MAIN_HOST=127.0.0.1
SQLSRV_MAIN_PORT=1433
SQLSRV_MAIN_DATABASE=BD_CRUCES
SQLSRV_MAIN_USERNAME=sa
SQLSRV_MAIN_PASSWORD=
SQLSRV_MAIN_ENCRYPT=yes
SQLSRV_MAIN_TRUST_SERVER_CERTIFICATE=true

# Conexión a RENIEC (opcional, puede ser la misma que arriba)
RENIEC_DB_HOST=127.0.0.1
RENIEC_DB_PORT=1433
RENIEC_DB_DATABASE=BD_CRUCES
RENIEC_DB_USERNAME=sa
RENIEC_DB_PASSWORD=
RENIEC_DB_ENCRYPT=yes
RENIEC_DB_TRUST_SERVER_CERTIFICATE=true

# Secret para generar tokens desde un endpoint HTTP controlado
API_TOKEN_GENERATOR_SECRET=change-me-long-random-string

# Días por defecto de expiración para tokens nuevos
API_TOKEN_DEFAULT_EXPIRES_IN_DAYS=30

SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync

CACHE_STORE=file
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
